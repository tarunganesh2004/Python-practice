  "MongoDB Find Advanced": {
    "prefix": "mongofind",
    "body": [
      "// ===== BASIC FIND =====",
      "db.students.find({})",
      "",
      "// ===== AND (multiple conditions) =====",
      "db.students.find({ age: { $gt: 20 }, gender: \"Male\" })",
      "",
      "// ===== OR =====",
      "db.students.find({ $or: [ { age: { $lt: 20 } }, { gender: \"Female\" } ] })",
      "",
      "// ===== COMBINED AND + OR =====",
      "db.students.find({",
      "  $and: [",
      "    { age: { $gte: 18 } },",
      "    { $or: [ { \"contact.address.city\": \"Bangalore\" }, { gender: \"Female\" } ] }",
      "  ]",
      "})",
      "",
      "// ===== OPERATORS =====",
      "db.students.find({ age: { $eq: 21 } })           // equal",
      "db.students.find({ age: { $ne: 21 } })           // not equal",
      "db.students.find({ age: { $gt: 20 } })           // greater",
      "db.students.find({ age: { $gte: 21 } })          // greater equal",
      "db.students.find({ age: { $lt: 25 } })           // less",
      "db.students.find({ age: { $lte: 21 } })          // less equal",
      "",
      "// ===== REAL WORLD =====",
      "// students with CGPA > 8 in any course",
      "db.students.find({ \"courses.marks\": { $gt: 80 } })"
    ],
    "description": "MongoDB find queries with AND, OR, and all operators"
  },
  "MongoDB Arrays": {
    "prefix": "mongoarr",
    "body": [
      "// ===== $all (must contain all values) =====",
      "db.students.find({ skills: { $all: [\"Python\", \"SQL\"] } })",
      "",
      "// ===== $elemMatch (multiple conditions in same object) =====",
      "db.students.find({",
      "  courses: {",
      "    $elemMatch: { courseName: \"DBMS\", \"result.grade\": \"A\" }",
      "  }",
      "})",
      "",
      "// ===== UPDATE ARRAY =====",
      "db.students.updateOne(",
      "  { studentId: \"S101\" },",
      "  { $addToSet: { skills: \"MongoDB\" } }       // avoids duplicates",
      ")"
    ],
    "description": "Array queries: all, elemMatch, addToSet"
  },
  "MongoDB Exists Null": {
    "prefix": "mongoexists",
    "body": [
      "// ===== FIELD EXISTS =====",
      "db.students.find({ middleName: { $exists: false } })",
      "",
      "// ===== NULL CHECK =====",
      "db.students.find({ middleName: null })        // null OR missing",
      "",
      "// ONLY NULL (not missing)",
      "db.students.find({ middleName: { $eq: null, $exists: true } })",
      "",
      "// ONLY MISSING",
      "db.students.find({ middleName: { $exists: false } })"
    ],
    "description": "Exists and null handling cases"
  },
  "MongoDB Projection": {
    "prefix": "mongoproj",
    "body": [
      "// ===== INCLUDE =====",
      "db.students.find({}, { name: 1, age: 1 })",
      "",
      "// ===== EXCLUDE =====",
      "db.students.find({}, { age: 0 })",
      "",
      "// ===== NESTED =====",
      "db.students.find({}, { \"contact.address.city\": 1 })",
      "",
      "// ===== ARRAY PROJECTION =====",
      "db.students.find({}, { \"courses.courseName\": 1 })"
    ],
    "description": "Projection examples"
  },
  "MongoDB Nested": {
    "prefix": "mongonested",
    "body": [
      "// ===== CHECK NESTED VALUE =====",
      "db.students.find({ \"contact.address.city\": \"Bangalore\" })",
      "",
      "// ===== ARRAY NESTED =====",
      "db.students.find({ \"courses.courseName\": \"DBMS\" })",
      "",
      "// ===== DOUBLE NESTED ARRAY =====",
      "db.students.find({ \"courses.result.grade\": \"A\" })"
    ],
    "description": "Nested and double nested queries"
  },
  "MongoDB Date Queries": {
    "prefix": "mongodate",
    "body": [
      "// ===== DATE RANGE =====",
      "db.students.find({",
      "  createdAt: {",
      "    $gte: ISODate(\"2025-01-01\"),",
      "    $lte: ISODate(\"2025-12-31\")",
      "  }",
      "})",
      "",
      "// ===== RECENT RECORDS =====",
      "db.students.find({ createdAt: { $gt: new Date(\"2025-06-01\") } })"
    ],
    "description": "Date filtering queries"
  },
  "MongoDB Aggregate Basic": {
    "prefix": "mongoagg",
    "body": [
      "db.students.aggregate([",
      "  { $match: { age: { $gt: 20 } } },",
      "  { $project: { name: 1, age: 1 } }",
      "])"
    ],
    "description": "Basic aggregation pipeline"
  },
  "MongoDB Advanced Pipeline": {
    "prefix": "mongoaggfull",
    "body": [
      "db.students.aggregate([",
      "",
      "  // ===== MATCH (multiple conditions) =====",
      "  {",
      "    $match: {",
      "      age: { $gte: 18 },",
      "      gender: \"Male\",",
      "      \"contact.address.city\": \"Bangalore\",",
      "      skills: { $in: [\"Python\"] },",
      "      isActive: true",
      "    }",
      "  },",
      "",
      "  // ===== UNWIND ARRAY =====",
      "  { $unwind: \"$courses\" },",
      "",
      "  // ===== FILTER COURSE =====",
      "  { $match: { \"courses.result.grade\": \"A\" } },",
      "",
      "  // ===== GROUP =====",
      "  {",
      "    $group: {",
      "      _id: \"$branch\",",
      "      avgMarks: { $avg: { $avg: \"$courses.marks\" } },",
      "      totalStudents: { $sum: 1 }",
      "    }",
      "  },",
      "",
      "  // ===== SORT =====",
      "  { $sort: { avgMarks: -1, totalStudents: -1 } },",
      "",
      "  // ===== LIMIT =====",
      "  { $limit: 5 },",
      "",
      "  // ===== PROJECT (RENAME) =====",
      "  {",
      "    $project: {",
      "      _id: 0,",
      "      branch: \"$_id\",",
      "      avgMarks: 1,",
      "      totalStudents: 1",
      "    }",
      "  }",
      "",
      "])"
    ],
    "description": "Full advanced aggregation pipeline with all operations"
  },
  "MongoDB Update Master": {
    "prefix": "mongoupd",
    "body": [
      "// ===== BASIC UPDATE =====",
      "db.students.updateOne(",
      "  { studentId: \"S101\" },",
      "  { $set: { age: 22 } }",
      ")",
      "",
      "// ===== UPDATE MULTIPLE =====",
      "db.students.updateMany(",
      "  { gender: \"Male\" },",
      "  { $set: { isActive: true } }",
      ")",
      "",
      "// ===== REMOVE FIELD =====",
      "db.students.updateOne(",
      "  { studentId: \"S101\" },",
      "  { $unset: { middleName: \"\" } }",
      ")",
      "",
      "// ===== INCREMENT =====",
      "db.students.updateOne(",
      "  { studentId: \"S101\" },",
      "  { $inc: { age: 1 } }",
      ")",
      "",
      "// ===== RENAME FIELD =====",
      "db.students.updateOne(",
      "  { studentId: \"S101\" },",
      "  { $rename: { \"contact.phone\": \"contact.mobile\" } }",
      ")",
      "",
      "// ===== ARRAY UPDATE =====",
      "db.students.updateOne(",
      "  { studentId: \"S101\" },",
      "  { $push: { skills: \"MongoDB\" } }",
      ")",
      "",
      "// avoid duplicates",
      "db.students.updateOne(",
      "  { studentId: \"S101\" },",
      "  { $addToSet: { skills: \"Python\" } }",
      ")",
      "",
      "// remove from array",
      "db.students.updateOne(",
      "  { studentId: \"S101\" },",
      "  { $pull: { skills: \"SQL\" } }",
      ")",
      "",
      "// ===== UPDATE NESTED FIELD =====",
      "db.students.updateOne(",
      "  { studentId: \"S101\" },",
      "  { $set: { \"contact.address.city\": \"Mysore\" } }",
      ")",
      "",
      "// ===== UPDATE ARRAY ELEMENT (positional) =====",
      "db.students.updateOne(",
      "  { \"courses.courseId\": \"C101\" },",
      "  { $set: { \"courses.$.courseName\": \"Advanced DBMS\" } }",
      ")",
      "",
      "// ===== MULTIPLE CONDITIONS =====",
      "db.students.updateMany(",
      "  { age: { $gt: 20 }, \"contact.address.city\": \"Bangalore\" },",
      "  { $set: { verified: true } }",
      ")"
    ],
    "description": "MongoDB update operations (all types)"
  },
  "MongoDB Ultimate Aggregation": {
    "prefix": "mongoult",
    "body": [
      "db.students.aggregate([",
      "",
      "  // ===== MATCH (multiple complex conditions) =====",
      "  {",
      "    $match: {",
      "      age: { $gte: 18, $lte: 30 },",
      "      gender: \"Male\",",
      "      isActive: true,",
      "      skills: { $in: [\"Python\", \"SQL\"] },",
      "      \"contact.address.city\": \"Bangalore\",",
      "      createdAt: { $gte: ISODate(\"2025-01-01\") }",
      "    }",
      "  },",
      "",
      "  // ===== ADD FIELD (month extraction) =====",
      "  {",
      "    $addFields: {",
      "      month: { $month: \"$createdAt\" },",
      "      year: { $year: \"$createdAt\" }",
      "    }",
      "  },",
      "",
      "  // ===== FILTER MONTH (example: after June) =====",
      "  { $match: { month: { $gt: 6 } } },",
      "",
      "  // ===== UNWIND COURSES ARRAY =====",
      "  { $unwind: \"$courses\" },",
      "",
      "  // ===== FILTER DOUBLE NESTED VALUES =====",
      "  {",
      "    $match: {",
      "      \"courses.result.grade\": { $in: [\"A\", \"B\"] },",
      "      \"courses.instructor.experience\": { $gte: 5 }",
      "    }",
      "  },",
      "",
      "  // ===== COMPUTE NEW VALUES =====",
      "  {",
      "    $addFields: {",
      "      avgMarks: { $avg: \"$courses.marks\" },",
      "      totalMarks: { $sum: \"$courses.marks\" },",
      "      performanceScore: {",
      "        $divide: [ { $sum: \"$courses.marks\" }, 3 ]",
      "      },",
      "      weightedScore: {",
      "        $multiply: [ { $avg: \"$courses.marks\" }, 1.2 ]",
      "      }",
      "    }",
      "  },",
      "",
      "  // ===== GROUP BY MULTIPLE FIELDS =====",
      "  {",
      "    $group: {",
      "      _id: {",
      "        branch: \"$courses.courseName\",",
      "        year: \"$year\"",
      "      },",
      "      avgScore: { $avg: \"$avgMarks\" },",
      "      totalStudents: { $sum: 1 },",
      "      allSkills: { $addToSet: \"$skills\" }",
      "    }",
      "  },",
      "",
      "  // ===== SORT (multiple fields) =====",
      "  { $sort: { avgScore: -1, totalStudents: 1 } },",
      "",
      "  // ===== LIMIT =====",
      "  { $limit: 10 },",
      "",
      "  // ===== PROJECT (rename + format output) =====",
      "  {",
      "    $project: {",
      "      _id: 0,",
      "      course: \"$_id.branch\",",
      "      year: \"$_id.year\",",
      "      averageScore: \"$avgScore\",",
      "      studentsCount: \"$totalStudents\",",
      "      skillsUsed: \"$allSkills\"",
      "    }",
      "  }",
      "",
      "])"
    ],
    "description": "Ultimate MongoDB aggregation covering all advanced operations"
  }
}
