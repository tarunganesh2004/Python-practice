    "prefix": "filehandlingbasic",
    "body": [
      "with open(\"students.txt\",\"r\") as f:",
      "    data=[]                                   # store cleaned lines",
      "    lines=f.readlines()",
      "",
      "    for line in lines:",
      "        if line.strip():                      # remove empty lines / header if needed",
      "            data.append(line.strip())         # removes \\n",
      "",
      "    new_data=[]                               # processed output list",
      "",
      "    for row in data:",
      "        cols=row.split(\",\")                # split columns",
      "",
      "        # extract fields",
      "        id=cols[0]",
      "        name=cols[1]",
      "        branch=cols[2]",
      "        sem=cols[3]",
      "        val=cols[5]",
      "",
      "        # update id",
      "        id=id.replace(\"S\",\"S-\")",
      "",
      "        # split name",
      "        parts=name.split(\" \")",
      "        fname=parts[0]",
      "        lname=parts[1] if len(parts)>1 else \"\"",
      "",
      "        # branch abbreviation",
      "        if branch==\"Computer Science\": b=\"CS\"",
      "        elif branch==\"Mechanical Engineering\": b=\"ME\"",
      "        elif branch==\"Electrical Engineering\": b=\"EE\"",
      "        else: b=\"OTH\"",
      "",
      "        # append processed row",
      "        new_data.append(f\"{id},{fname},{lname},{b},{sem},{val}\")",
      "",
      "    # display output",
      "    print(\"ID, FirstName, LastName, Branch, Semester, Value\")",
      "    for r in new_data:",
      "        print(r.replace(\",\",\", \"))",
      "",
      "with open(\"processed_students.txt\",\"w\") as f:",
      "    f.write(\"ID,FirstName,LastName,Branch,Semester,Value\\n\")   # header",
      "    f.write(\"\\n\".join(new_data))                               # no extra blank lines",
      "    f.write(\"\\n\")                                              # final newline"
    ],
