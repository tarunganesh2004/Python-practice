  "Python Full File Processing Pipeline": {
    "prefix": "filehandling_full",
    "body": [
      "# Example: Student data processing (single line per record)",
      "",
      "with open(\"students.txt\",\"r\") as f:",
      "    lines = f.readlines()",
      "",
      "    data = []",
      "",
      "    for i, line in enumerate(lines):",
      "        if i == 0:",
      "            continue                          # skip header",
      "        if line.strip():",
      "            data.append(line.strip())         # remove \\n",
      "",
      "    processed = []                            # store updated rows",
      "",
      "    for row in data:",
      "        cols = row.split(\",\")                # split columns",
      "",
      "        # extract fields",
      "        sid = cols[0]",
      "        name = cols[1]",
      "        branch = cols[2]",
      "        sem = int(cols[3])                    # convert to int",
      "        cgpa = float(cols[5])                 # convert to float",
      "",
      "        # update values",
      "        sid = sid.replace(\"S\",\"S-\")        # modify id",
      "",
      "        # split name",
      "        parts = name.split(\" \")",
      "        fname = parts[0]",
      "        lname = parts[1] if len(parts)>1 else \"\"",
      "",
      "        # new computed column (grade)",
      "        if cgpa >= 8.5: grade = \"A\"",
      "        elif cgpa >= 7: grade = \"B\"",
      "        else: grade = \"C\"",
      "",
      "        # branch abbreviation",
      "        if branch == \"Computer Science\": b = \"CS\"",
      "        elif branch == \"Mechanical Engineering\": b = \"ME\"",
      "        elif branch == \"Electrical Engineering\": b = \"EE\"",
      "        else: b = \"OTH\"",
      "",
      "        # filtering (only good students)",
      "        if cgpa < 6:",
      "            continue                          # skip low CGPA",
      "",
      "        # append updated row",
      "        processed.append([sid, fname, lname, b, sem, cgpa, grade])",
      "",
      "    # sorting (by CGPA descending)",
      "    processed.sort(key=lambda x: x[5], reverse=True)",
      "",
      "    # aggregation (average CGPA)",
      "    total = sum(x[5] for x in processed)",
      "    count = len(processed)",
      "    avg = total / count if count else 0",
      "",
      "    print(f\"Average CGPA: {avg}\")",
      "",
      "    # convert back to string rows",
      "    output = []",
      "    for r in processed:",
      "        output.append(\",\".join(map(str, r)))",
      "",
      "with open(\"output.txt\",\"w\") as f:",
      "    f.write(\"ID,FirstName,LastName,Branch,Sem,CGPA,Grade\\n\")",
      "    f.write(\"\\n\".join(output))              # single \\n → no extra blank lines",
      "    f.write(\"\\n\")                           # final newline"
    ],
    "description": "Full pipeline: read → remove header → transform → filter → sort → aggregate → write"
  },
